<%- include('partials/head', {base, pageTitle: 'Anime Details', pageDesc: 'Watch this anime free in HD on ToxicWatch.'}) %>
</head>
<body>
<canvas id="techCanvas"></canvas>
<%- include('partials/preloader') %>
<%- include('partials/nav') %>

<div id="detailBanner" class="detail-banner"></div>

<div style="position:relative;z-index:2;padding-top:260px">
  <div class="section-inner">
    <div class="breadcrumb anim-el"><a href="<%= base %>/">Home</a><i class="fas fa-chevron-right"></i><span id="breadAnime">Anime</span></div>
  </div>
  <div class="anime-detail">
    <div class="detail-sidebar anim-el from-left">
      <div class="detail-poster"><img id="detailPoster" src="" alt="Anime Poster" onerror="this.src='https://via.placeholder.com/260x380/13161f/a78bfa?text=No+Image'"></div>
      <div class="detail-stats" id="detailStats"></div>
    </div>
    <div class="detail-main anim-el">
      <div id="detailTitleNative" class="detail-title-native"></div>
      <h1 class="detail-title" id="detailTitle">Loading…</h1>
      <div class="detail-score-row" id="detailScoreRow"></div>
      <div class="genre-tags" id="detailGenres"></div>
      <p class="detail-desc" id="detailDesc"></p>
      <div class="detail-btns" id="detailBtns"></div>

      <div style="margin-bottom:28px">
        <div class="ep-section-head">
          <div class="section-title"><i class="fas fa-list"></i>Episodes</div>
          <span class="ep-count-badge" id="epCountBadge">Loading…</span>
        </div>
        <div id="epGrid" class="ep-list">
          <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
      </div>

      <div id="charSection" style="display:none;margin-bottom:28px">
        <div class="section-title" style="margin-bottom:14px"><i class="fas fa-users"></i>Characters</div>
        <div class="char-grid" id="charGrid"></div>
      </div>

      <div id="recSection" style="display:none;margin-bottom:28px">
        <div class="section-title" style="margin-bottom:14px"><i class="fas fa-thumbs-up"></i>Recommendations</div>
        <div class="rec-grid" id="recGrid"></div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script src="<%= base %>/static/js/app.js"></script>
<script>var __ANIME_ID__ = '<%= animeId %>';</script>
<script src="<%= base %>/static/js/anime.js"></script>
</body>
</html>
